{
  "buildCommand": "if [ \"$VERCEL_ENV\" == \"preview\" ]; then yarn vercel-preview-build; else yarn vercel-build; fi",
  "crons": [
    {
      "path": "/api/cron/lifecycle",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/webhook-deliveries",
      "schedule": "* * * * *"
    }
  ],
  "git": {
    "deploymentEnabled": {
      "development": false,
      "main": true,
      "preview": true
    }
  },
  "headers": [
    {
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ],
      "source": "/.well-known/microsoft-identity-association.json"
    }
  ]
}
